@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using TripPlanner.Contracts.Profile
@using TripPlanner.Web.Features.Timezones
@inject IProfileApiClient ProfileApi
@inject TripPlanner.Web.Features.Maps.IMapPreferenceProvider MapPreference
@inject ITimezoneOptionsProvider TimezoneOptions

<PageTitle>Profile</PageTitle>

<section class="profile-page">
<h1 class="mb-3">Profile</h1>

@if (_isLoading)
{
    <div class="text-secondary">Loading profile...</div>
}
else if (_loadError is not null)
{
    <div class="alert alert-warning" role="alert">@_loadError</div>
}
else if (_model is not null)
{
    @if (_saveMessage is not null)
    {
        <div class="alert alert-success" role="status">@_saveMessage</div>
    }
    @if (_saveError is not null)
    {
        <div class="alert alert-danger" role="alert">@_saveError</div>
    }
    @if (!_isComplete)
    {
        <div class="alert alert-info" role="status">Complete your display name and email so Trip Planner can personalize your experience and send approved trip notifications.</div>
    }

    <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="profile-form">
        <DataAnnotationsValidator />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label" for="firstName">First name</label>
                <InputText id="firstName" class="form-control" @bind-Value="_model.FirstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="lastName">Last name</label>
                <InputText id="lastName" class="form-control" @bind-Value="_model.LastName" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="displayName">Display name</label>
                <InputText id="displayName" class="form-control" @bind-Value="_model.DisplayName" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="_model.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="timeZoneId">Default timezone</label>
                <InputSelect id="timeZoneId" class="form-select" @bind-Value="_model.TimeZoneId">
                    <option value="">Select a timezone</option>
                    @foreach (var option in TimezoneOptions.GetOptions())
                    {
                        <option value="@option.Id">@option.DisplayName (@option.Id)</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _model.TimeZoneId)" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="mapProvider">Default map</label>
                <InputSelect id="mapProvider" class="form-select" @bind-Value="_model.MapProvider">
                    <option value="@MapProviders.Bing">Bing Maps</option>
                    <option value="@MapProviders.Google">Google Maps</option>
                </InputSelect>
                <div class="form-text">Used when you open an event location on a map.</div>
            </div>
        </div>

        <h2 class="h4 mt-4">Notifications</h2>
        <p class="text-secondary">Choose how you want to be notified. Changes apply to future notifications only.</p>
        <div class="row g-3">
            @foreach (var category in _model.NotificationCategories)
            {
                <div class="col-md-6">
                    <fieldset class="notification-category h-100" aria-label="@category.DisplayName">
                        <legend class="h6 mb-1">@category.DisplayName</legend>
                        <div class="form-check">
                            <InputCheckbox id="@($"notif-{category.Category}-inapp")" class="form-check-input" @bind-Value="category.InAppEnabled" />
                            <label class="form-check-label" for="@($"notif-{category.Category}-inapp")">In-app</label>
                        </div>
                        <div class="form-check">
                            <InputCheckbox id="@($"notif-{category.Category}-email")" class="form-check-input" @bind-Value="category.EmailEnabled" />
                            <label class="form-check-label" for="@($"notif-{category.Category}-email")">Email</label>
                        </div>
                        <p class="small text-secondary mb-0" data-testid="@($"notif-{category.Category}-summary")">@DescribeCategoryState(category)</p>
                    </fieldset>
                </div>
            }
        </div>

        <h2 class="h4 mt-4">Personalization</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label" for="travelInterests">Travel interests</label>
                <InputText id="travelInterests" class="form-control" @bind-Value="_model.TravelInterests" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="homeAirport">Home airport</label>
                <InputText id="homeAirport" class="form-control" @bind-Value="_model.HomeAirport" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="preferredTravelStyle">Preferred travel style</label>
                <InputText id="preferredTravelStyle" class="form-control" @bind-Value="_model.PreferredTravelStyle" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="accessibilityNotes">Accessibility notes</label>
                <InputText id="accessibilityNotes" class="form-control" @bind-Value="_model.AccessibilityNotes" />
            </div>
        </div>

        <button class="btn btn-primary mt-4" type="submit" disabled="@_isSaving">@(_isSaving ? "Saving..." : "Save profile")</button>
    </EditForm>
}
</section>

@code {
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isComplete;
    private string? _loadError;
    private string? _saveError;
    private string? _saveMessage;
    private ProfileFormModel? _model;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await ProfileApi.GetAsync();
            if (profile is null)
            {
                _loadError = "We couldn't load your profile right now.";
                return;
            }

            ApplyProfile(profile);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_model is null) return;

        _isSaving = true;
        _saveError = null;
        _saveMessage = null;

        try
        {
            var request = new UpdateUserProfileRequest(
                _model.FirstName,
                _model.LastName,
                _model.DisplayName,
                _model.Email,
                _model.TimeZoneId,
                MapProviders.Normalize(_model.MapProvider),
                new NotificationPreferences(_model.NotificationCategories
                    .Select(c => new NotificationCategoryPreference(c.Category, c.DisplayName, c.InAppEnabled, c.EmailEnabled))
                    .ToArray()),
                new PersonalizationPreferences(_model.TravelInterests, _model.HomeAirport, _model.PreferredTravelStyle, _model.AccessibilityNotes));

            var saved = await ProfileApi.SaveAsync(request);
            MapPreference.Invalidate();
            ApplyProfile(saved);
            _saveMessage = "Profile saved. Notification changes apply to future notifications.";
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ApplyProfile(UserProfileResponse profile)
    {
        _isComplete = profile.IsComplete;
        _model = new ProfileFormModel
        {
            FirstName = profile.FirstName,
            LastName = profile.LastName,
            DisplayName = profile.DisplayName,
            Email = profile.Email,
            TimeZoneId = profile.TimeZoneId,
            MapProvider = MapProviders.Normalize(profile.MapProvider),
            NotificationCategories = profile.NotificationPreferences.Categories
                .Select(c => new CategoryPreferenceModel
                {
                    Category = c.Category,
                    DisplayName = c.DisplayName,
                    InAppEnabled = c.InAppEnabled,
                    EmailEnabled = c.EmailEnabled
                })
                .ToList(),
            TravelInterests = profile.PersonalizationPreferences.TravelInterests,
            HomeAirport = profile.PersonalizationPreferences.HomeAirport,
            PreferredTravelStyle = profile.PersonalizationPreferences.PreferredTravelStyle,
            AccessibilityNotes = profile.PersonalizationPreferences.AccessibilityNotes
        };
    }

    private static string DescribeCategoryState(CategoryPreferenceModel category)
    {
        if (category is { InAppEnabled: true, EmailEnabled: true })
        {
            return "You'll be notified in-app and by email.";
        }

        if (category is { InAppEnabled: true, EmailEnabled: false })
        {
            return "You'll be notified in-app only.";
        }

        if (category is { InAppEnabled: false, EmailEnabled: true })
        {
            return "You'll be notified by email only.";
        }

        return "You won't be notified about this.";
    }

    private sealed class ProfileFormModel
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? DisplayName { get; set; }
        public string? Email { get; set; }
        [Required(ErrorMessage = "Timezone is required.")]
        public string TimeZoneId { get; set; } = "UTC";
        public string MapProvider { get; set; } = MapProviders.Bing;
        public List<CategoryPreferenceModel> NotificationCategories { get; set; } = new();
        public string? TravelInterests { get; set; }
        public string? HomeAirport { get; set; }
        public string? PreferredTravelStyle { get; set; }
        public string? AccessibilityNotes { get; set; }
    }

    private sealed class CategoryPreferenceModel
    {
        public string Category { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public bool InAppEnabled { get; set; }
        public bool EmailEnabled { get; set; }
    }
}
