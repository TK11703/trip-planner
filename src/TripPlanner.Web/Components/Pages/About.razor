@page "/about"

<PageTitle>Trip Planner — About</PageTitle>

<h1 class="mb-3">About Trip Planner</h1>
<p class="lead">Trip Planner is a modern itinerary tool for individual travelers who want a polished, private way to track their plans without sharing data.</p>

<div class="row g-3 mt-2">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Personal by default</h2>
                <p class="mb-0">Trips, legs, and tracked items are scoped to your Azure Entra identity. No personal data is rendered on public pages.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Built on .NET 10 + Aspire</h2>
                <p class="mb-0">A Blazor Web App, Minimal API, and PostgreSQL composed locally with Aspire and container-ready for Azure Container Apps.</p>
            </div>
        </div>
    </div>
</div>
