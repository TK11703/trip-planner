@page "/about"

<PageTitle>Trip Planner — About</PageTitle>

<BrandSurface Eyebrow="About the expedition" Title="A private base camp for personal travel plans" Class="mb-4">
    <p class="lead mb-0">Trip Planner helps individual travelers turn scattered ideas into a clear, secure itinerary without sharing personal trip data on public surfaces.</p>
</BrandSurface>

<div class="row g-3 mt-2">
    <div class="col-md-6">
        <div class="card h-100 modern-card">
            <div class="card-body">
                <p class="brand-eyebrow">Personal by default</p>
                <h2 class="h5">Your route stays in your account</h2>
                <p class="mb-0 text-secondary">Trips, legs, and tracked items are scoped to your Azure Entra identity. No personal data is rendered on public pages.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 modern-card">
            <div class="card-body">
                <p class="brand-eyebrow">Container ready</p>
                <h2 class="h5">Built on .NET 10 + Aspire</h2>
                <p class="mb-0 text-secondary">A Blazor Web App, Minimal API, and PostgreSQL stack composed locally with Aspire and ready for container hosting.</p>
            </div>
        </div>
    </div>
</div>
