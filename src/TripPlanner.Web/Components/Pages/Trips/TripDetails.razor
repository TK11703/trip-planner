@page "/trips/{TripId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ITripApiClient TripApi
@inject NavigationManager Nav

<PageTitle>Trip details</PageTitle>

@if (_loading)
{
    <TripAccessState State="TripAccessState.TripAccessStateKind.Loading" />
}
else if (_trip is null)
{
    <TripAccessState State="TripAccessState.TripAccessStateKind.NotFoundOrDenied" />
}
else
{
    <header class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="mb-1">@_trip.Name</h1>
            <p class="text-secondary mb-0">@_trip.StartDate.ToLongDateString() - @_trip.EndDate.ToLongDateString()</p>
            @if (!_trip.IsOwner)
            {
                <span class="badge @AccessBadgeClass mt-2">Shared - @AccessLevelLabel</span>
            }
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/trips">All trips</a>
            @if (_trip.IsOwner)
            {
                <a class="btn btn-outline-secondary" href="@($"/trips/{TripId}/print")">Print</a>
                <button class="btn btn-outline-primary" @onclick="OpenShareModal">Share</button>
            }
            @if (CanEditContent)
            {
                <div class="btn-group">
                    <button type="button" class="btn btn-primary" @onclick="OpenTripEditModal">Edit trip</button>
                    @if (_trip.IsOwner)
                    {
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle trip actions</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><button class="dropdown-item text-danger" type="button" @onclick="OpenDeleteModal">Delete trip</button></li>
                        </ul>
                    }
                </div>
            }
        </div>
    </header>

    <div class="row g-3">
        <div class="col-12">
            <div class="card shadow-sm mb-3 tp-static">
                <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <div class="fw-semibold">Trip timeline</div>
                        <div class="small text-secondary">Trip legs are listed on the left. Scroll the grid to see each day, hour, and the events on each leg. Select a leg or event to edit it.</div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                @onclick="OpenMapModal" disabled="@(!CanOpenMap)"
                                title="@(CanOpenMap ? "View all trip locations on a map" : "Add a location to an event to view the map")"
                                aria-label="View all trip locations on a map">
                            View map
                        </button>
                        @{
                            var navDates = _timeline?.TripDates ?? (IReadOnlyList<DateOnly>)Array.Empty<DateOnly>();
                            var navCurrent = _timeline?.CurrentDate;
                        }
                        <div class="btn-group btn-group-sm" role="group" aria-label="Step timeline by day">
                            <button type="button" class="btn btn-outline-secondary"
                                    title="Previous day" aria-label="Go to previous day"
                                    disabled="@(_timeline is null || _timeline.AtTripStart)"
                                    @onclick="GoToPreviousDayAsync">
                                <span aria-hidden="true">&lsaquo;</span>
                            </button>
                            <button type="button" class="btn btn-outline-secondary"
                                    title="Next day" aria-label="Go to next day"
                                    disabled="@(_timeline is null || _timeline.AtTripEnd)"
                                    @onclick="GoToNextDayAsync">
                                <span aria-hidden="true">&rsaquo;</span>
                            </button>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    aria-label="Jump to a date in the trip"
                                    disabled="@(navDates.Count == 0)">
                                Jump to date@(navCurrent is { } jc ? $": {jc:ddd M/d}" : "")
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end tp-jump-menu">
                                <li><h6 class="dropdown-header">Shortcuts</h6></li>
                                <li><button type="button" class="dropdown-item" @onclick="GoToTripStartAsync">Trip start</button></li>
                                @if (_timeline?.TodayInRange == true)
                                {
                                    <li><button type="button" class="dropdown-item" @onclick="GoToTodayAsync">Today</button></li>
                                }
                                <li><button type="button" class="dropdown-item" @onclick="GoToTripEndAsync">Trip end</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Dates</h6></li>
                                @foreach (var date in navDates)
                                {
                                    var jumpDate = date;
                                    var isActive = navCurrent == jumpDate;
                                    <li>
                                        <button type="button"
                                                class="dropdown-item d-flex justify-content-between align-items-center @(isActive ? "active" : null)"
                                                @onclick="() => JumpToDateAsync(jumpDate)">
                                            <span>@jumpDate.ToString("ddd, MMM d")</span>
                                            @if (isActive)
                                            {
                                                <span class="ms-2" aria-hidden="true">&#10003;</span>
                                            }
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <TripTimeline @ref="_timeline" TripId="@TripId" CanEdit="@CanEditContent" OnLegSelected="OnTimelineLegSelected" OnItemSelected="OnTimelineItemSelected" OnLegSlotSelected="OnTimelineLegSlotSelected" OnAddLegRequested="OpenCreateLegModal" OnLoaded="HandleTimelineLoaded" OnActiveDateChanged="HandleActiveDateChanged" />
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card mb-3">
                <div class="card-header">Overview</div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(_trip.Description))
                    {
                        <p class="mb-2">@_trip.Description</p>
                    }
                    else
                    {
                        <p class="text-secondary mb-2">No description yet.</p>
                    }
                    <div class="small text-secondary">Created @_trip.CreatedAtUtc.ToString("yyyy-MM-dd")</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card mb-3">
                <div class="card-header">Itinerary summary</div>
                <ul class="list-group list-group-flush small">
                    <li class="list-group-item d-flex justify-content-between"><span>Legs</span><span>@_trip.Legs.Count</span></li>
                    <li class="list-group-item d-flex justify-content-between"><span>Events</span><span>@_trip.TrackedItems.Count</span></li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Estimated total</span>
                        @if (_trip.EstimatedCostTotal > 0)
                        {
                            <span>@_trip.EstimatedCostTotal.ToString("C")</span>
                        }
                        else
                        {
                            <span class="text-secondary">No estimates yet</span>
                        }
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>People with access</span>
                    @if (_trip.IsOwner)
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="OpenShareModal">Manage</button>
                    }
                </div>
                @{
                    var sharedPeople = _trip.SharedPeople ?? Array.Empty<TripShareMember>();
                    var hasMembers = sharedPeople.Any(p => p.AccessLevel != TripAccessLevel.Owner);
                }
                @if (sharedPeople.Count == 0)
                {
                    <div class="card-body">
                        @if (_trip.IsOwner)
                        {
                            <p class="text-secondary mb-0">This trip isn't shared yet. Select Share to invite viewers or collaborators.</p>
                        }
                        else
                        {
                            <p class="text-secondary mb-0">No one else has access to this trip yet.</p>
                        }
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush small">
                        @foreach (var person in sharedPeople)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center gap-2">
                                <span class="text-truncate">@(string.IsNullOrWhiteSpace(person.DisplayName) ? person.Email ?? person.UserId : person.DisplayName)</span>
                                <span class="badge @AccessBadge(person.AccessLevel)">
                                    @AccessText(person.AccessLevel)
                                </span>
                            </li>
                        }
                    </ul>
                    @if (_trip.IsOwner && !hasMembers)
                    {
                        <div class="card-body py-2">
                            <p class="text-secondary small mb-0">Only you have access. Select Manage to invite viewers or collaborators.</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @if (_showShareModal)
    {
        <ShareTripModal TripId="@TripId" OnClose="CloseShareModal" OnChanged="ReloadAsync" />
    }

    @if (_showMapModal)
    {
        <TripPlanner.Web.Components.Trips.TripMapModal TripId="@TripId" OnClose="CloseMapModal" OnOpenEvent="HandleMapOpenEventAsync" />
    }

    @if (_activeModal is not ActiveModal.None)
    {
        <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title h5">@ModalTitle</h2>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        @switch (_activeModal)
                        {
                            case ActiveModal.EditTrip:
                                <div class="alert alert-warning small" role="alert">
                                    Changing trip dates can leave existing legs or events outside the trip range. Review the calendar after saving.
                                </div>
                                <TripForm Model="_tripEditModel" IsEdit="true" OnSubmit="HandleTripEditAsync" />
                                break;
                            case ActiveModal.CreateLeg:
                                <TripLegForm TripId="@TripId" OnSaved="HandleModalSavedAsync" />
                                break;
                            case ActiveModal.EditLeg:
                                <TripLegForm TripId="@TripId" Leg="_editingLeg" OnSaved="HandleModalSavedAsync" />
                                break;
                            case ActiveModal.CreateItem:
                                <TrackedItemForm TripId="@TripId" Legs="_trip.Legs" InitialTripLegId="_initialItemLegId" InitialStartsAt="_initialItemStart" OnSaved="HandleModalSavedAsync" />
                                break;
                            case ActiveModal.EditItem:
                                <TrackedItemForm TripId="@TripId" Item="_editingItem" Legs="_trip.Legs" OnSaved="HandleModalSavedAsync" />
                                break;
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop show"></div>
    }

    @if (_showDeleteModal)
    {
        <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title h5">Delete trip</h2>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteModal" disabled="@_isDeleting"></button>
                    </div>
                    <div class="modal-body">
                        @if (_deleteError is not null)
                        {
                            <div class="alert alert-danger small" role="alert">@_deleteError</div>
                        }
                        <p class="mb-0">Are you sure you want to delete <strong>@_trip.Name</strong>? This permanently removes the trip and all of its legs, events, and shares. This can't be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseDeleteModal" disabled="@_isDeleting">Cancel</button>
                        <button type="button" class="btn btn-danger" @onclick="HandleTripDeleteAsync" disabled="@_isDeleting">@(_isDeleting ? "Deleting…" : "Delete trip")</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop show"></div>
    }
}

@code {
    [Parameter] public Guid TripId { get; set; }

    private bool _loading = true;
    private TripDetail? _trip;
    private TripTimeline? _timeline;
    private ActiveModal _activeModal = ActiveModal.None;
    private bool _showShareModal;
    private bool _showMapModal;
    private TripPlanner.Web.Components.Trips.TripForm.TripFormModel _tripEditModel = new();
    private TripLegDto? _editingLeg;
    private TrackedItemDto? _editingItem;
    private Guid? _initialItemLegId;
    private DateTime? _initialItemStart;
    private bool _showDeleteModal;
    private bool _isDeleting;
    private string? _deleteError;

    private bool CanEditContent => _trip is not null && (_trip.IsOwner || _trip.AccessLevel == TripAccessLevel.Collaborator);
    private bool CanOpenMap => _trip is not null && _trip.TrackedItems.Any(i => IsLocationMappable(i.Location));
    private string AccessLevelLabel => _trip?.AccessLevel == TripAccessLevel.Collaborator ? "Collaborator" : "Viewer";
    private string AccessBadgeClass => _trip?.AccessLevel == TripAccessLevel.Collaborator ? "text-bg-success" : "text-bg-secondary";

    // Matches the globe's rule: a location is map-capable when non-empty, has a letter/digit, and is <=200 chars.
    private static bool IsLocationMappable(string? location)
    {
        if (string.IsNullOrWhiteSpace(location))
        {
            return false;
        }
        var trimmed = location.Trim();
        return trimmed.Length <= 200 && trimmed.Any(char.IsLetterOrDigit);
    }

    private static string AccessBadge(TripAccessLevel level) => level switch
    {
        TripAccessLevel.Owner => "text-bg-dark",
        TripAccessLevel.Collaborator => "text-bg-success",
        _ => "text-bg-secondary"
    };

    private static string AccessText(TripAccessLevel level) => level switch
    {
        TripAccessLevel.Owner => "Owner",
        TripAccessLevel.Collaborator => "Collaborator",
        _ => "Viewer"
    };

    private enum ActiveModal
    {
        None,
        EditTrip,
        CreateLeg,
        EditLeg,
        CreateItem,
        EditItem
    }

    private string ModalTitle => _activeModal switch
    {
        ActiveModal.EditTrip => "Edit trip",
        ActiveModal.CreateLeg => "Add leg",
        ActiveModal.EditLeg => "Edit leg",
        ActiveModal.CreateItem => "Add event",
        ActiveModal.EditItem => "Edit event",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        if (_trip is null)
        {
            _loading = true;
        }
        try
        {
            _trip = await TripApi.GetDetailAsync(TripId);
            if (_trip is not null && _activeModal != ActiveModal.EditTrip)
            {
                PopulateTripEditModel();
            }
        }
        catch
        {
            _trip = null;
        }
        finally
        {
            _loading = false;
        }
        if (_timeline is not null)
        {
            await _timeline.RefreshAsync();
        }
        StateHasChanged();
    }

    private void PopulateTripEditModel()
    {
        if (_trip is null) return;
        _tripEditModel = new TripPlanner.Web.Components.Trips.TripForm.TripFormModel
        {
            Name = _trip.Name,
            Description = _trip.Description,
            StartDate = _trip.StartDate.ToDateTime(TimeOnly.MinValue),
            EndDate = _trip.EndDate.ToDateTime(TimeOnly.MinValue)
        };
    }

    private void OpenTripEditModal()
    {
        PopulateTripEditModel();
        _activeModal = ActiveModal.EditTrip;
    }

    private void OpenDeleteModal()
    {
        _deleteError = null;
        _isDeleting = false;
        _showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        if (_isDeleting) return;
        _showDeleteModal = false;
        _deleteError = null;
    }

    private void OpenShareModal() => _showShareModal = true;

    private void CloseShareModal() => _showShareModal = false;

    private void OpenMapModal() => _showMapModal = true;

    private void CloseMapModal() => _showMapModal = false;

    private async Task HandleMapOpenEventAsync(Guid trackedItemId)
    {
        var item = _trip?.TrackedItems.FirstOrDefault(i => i.TrackedItemId == trackedItemId);
        if (item is null)
        {
            return;
        }
        _showMapModal = false;
        if (CanEditContent)
        {
            OpenEditItemModal(item);
        }
        await Task.CompletedTask;
    }

    private void OpenCreateLegModal()
    {
        _editingLeg = null;
        _activeModal = ActiveModal.CreateLeg;
    }

    private void OpenEditLegModal(TripLegDto leg)
    {
        _editingLeg = leg;
        _activeModal = ActiveModal.EditLeg;
    }

    private void OpenCreateItemModal()
    {
        _editingItem = null;
        _initialItemLegId = null;
        // Default a new event to the timeline's active (centered) date when available.
        _initialItemStart = _timeline?.CurrentDate is { } activeDate
            ? activeDate.ToDateTime(new TimeOnly(9, 0))
            : null;
        _activeModal = ActiveModal.CreateItem;
    }

    private void OpenEditItemModal(TrackedItemDto item)
    {
        _editingItem = item;
        _activeModal = ActiveModal.EditItem;
    }

    private void CloseModal()
    {
        _activeModal = ActiveModal.None;
        _editingLeg = null;
        _editingItem = null;
    }

    private async Task HandleTripEditAsync(TripPlanner.Web.Components.Trips.TripForm.TripFormModel model)
    {
        var request = new UpdateTripRequest(
            model.Name.Trim(),
            string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim(),
            DateOnly.FromDateTime(model.StartDate),
            DateOnly.FromDateTime(model.EndDate));
        await TripApi.UpdateAsync(TripId, request);
        CloseModal();
        await ReloadAsync();
    }

    private async Task HandleTripDeleteAsync()
    {
        _deleteError = null;
        _isDeleting = true;
        try
        {
            await TripApi.DeleteTripAsync(TripId);
            Nav.NavigateTo("/trips");
        }
        catch
        {
            _deleteError = "We couldn't delete this trip. Please try again.";
            _isDeleting = false;
        }
    }

    private async Task HandleModalSavedAsync()
    {
        CloseModal();
        await ReloadAsync();
    }

    private void OnTimelineLegSelected(Guid tripLegId)
    {
        if (!CanEditContent) return;
        var leg = _trip?.Legs.FirstOrDefault(l => l.TripLegId == tripLegId);
        if (leg is not null)
        {
            OpenEditLegModal(leg);
        }
    }

    private void OnTimelineItemSelected(Guid trackedItemId)
    {
        if (!CanEditContent) return;
        var item = _trip?.TrackedItems.FirstOrDefault(i => i.TrackedItemId == trackedItemId);
        if (item is not null)
        {
            OpenEditItemModal(item);
        }
    }

    private void OnTimelineLegSlotSelected(TripTimeline.TimelineSlotSelection selection)
    {
        if (!CanEditContent) return;
        _editingItem = null;
        _initialItemLegId = selection.TripLegId;
        _initialItemStart = selection.StartLocal;
        _activeModal = ActiveModal.CreateItem;
    }

    private async Task JumpToDateAsync(DateOnly date)
    {
        if (_timeline is not null) await _timeline.ScrollToDateAsync(date);
    }

    private async Task GoToNextDayAsync()
    {
        if (_timeline is not null) await _timeline.GoToNextDayAsync();
    }

    private async Task GoToPreviousDayAsync()
    {
        if (_timeline is not null) await _timeline.GoToPreviousDayAsync();
    }

    private async Task GoToTripStartAsync()
    {
        if (_timeline is not null) await _timeline.GoToTripStartAsync();
    }

    private async Task GoToTripEndAsync()
    {
        if (_timeline is not null) await _timeline.GoToTripEndAsync();
    }

    private async Task GoToTodayAsync()
    {
        if (_timeline is not null) await _timeline.GoToTodayAsync();
    }

    private void HandleTimelineLoaded() => StateHasChanged();

    private void HandleActiveDateChanged(DateOnly activeDate) => StateHasChanged();
}
