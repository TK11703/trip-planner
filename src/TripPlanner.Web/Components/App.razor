@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en" data-bs-theme="@_theme" data-theme-mode="@_theme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="@(_theme == "dark" ? "#0a1017" : "#f3f7f9")" />
    <base href="/" />
    <ResourcePreloader />
    <script src="js/themeMode.js"></script>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["css/app.css"]" />
    <link rel="stylesheet" href="@Assets["TripPlanner.Web.styles.css"]" />
    <script src="js/tripTimeline.js" defer></script>
    <script src="js/tripPrint.js" defer></script>
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="img/brand/trip-planner-globe.svg" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["lib/bootstrap/dist/js/bootstrap.bundle.min.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    // Render the persisted theme on the server (from a cookie kept in sync with
    // the account preference) so the first paint is already correct and the
    // toggle/page do not visibly flip from light to dark on load.
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string _theme = "light";

    protected override void OnInitialized()
    {
        var cookie = HttpContext?.Request.Cookies["tp-theme"];
        _theme = cookie == "dark" ? "dark" : "light";
    }
}
