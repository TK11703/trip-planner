@inject ITripApiClient TripApi
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using TripPlanner.Contracts.Common
@using TripPlanner.Contracts.Timeline
@using TripPlanner.Contracts.TripItems

@if (_timeline is null)
{
    <div class="text-secondary small py-4">Loading trip timeline…</div>
}
else if (_timeline.Legs.Count == 0 && _timeline.UnassignedItems.Count == 0)
{
    <div class="border-dashed rounded p-4 text-center text-secondary">
        No trip legs yet. Add a trip leg to start building your timeline, then relate events to it.
    </div>
}
else
{
    @if (_timeline.UnassignedItems.Count > 0)
    {
        <div class="alert alert-warning py-2 small mb-2">
            @_timeline.UnassignedItems.Count event(s) are not related to a trip leg. Select one below to assign it to a leg.
        </div>
    }
    <div class="ttl" style="--ttl-slot-w:@(SlotWidthPx)px; --ttl-label-w:@(LabelWidthPx)px;">
        <div class="ttl-scroll" @ref="_scrollEl">
            <div class="ttl-grid" style="grid-template-columns: var(--ttl-label-w) @(TrackWidthPx)px;">
                <div class="ttl-corner ttl-corner-day">Trip legs</div>
                <div class="ttl-days">
                    @for (var d = 0; d < _days; d++)
                    {
                        var date = _start.AddDays(d);
                        <div class="ttl-day" style="width:@(SlotsPerDay * SlotWidthPx)px"><span class="ttl-day-label">@date.ToString("ddd M/d")</span></div>
                    }
                </div>

                <div class="ttl-corner ttl-corner-hour"></div>
                <div class="ttl-hours">
                    @for (var d = 0; d < _days; d++)
                    {
                        @for (var h = 0; h < 24; h++)
                        {
                            <div class="ttl-hour" style="width:@(2 * SlotWidthPx)px">@FormatHour(h)</div>
                        }
                    }
                </div>

                @{
                    RenderFragment laneGrid =
                        @<div class="ttl-lane-grid">
                            @for (var gd = 0; gd < _days; gd++)
                            {
                                @for (var gh = 0; gh < 24; gh++)
                                {
                                    <div class="ttl-lane-hour @(gh == 23 ? "ttl-lane-hour-dayend" : null)" style="width:@(2 * SlotWidthPx)px"></div>
                                }
                            }
                        </div>;
                }

                @foreach (var leg in _timeline.Legs)
                {
                    var legLanes = AssignLanes(leg.Items);
                    var legLaneCount = LaneCount(legLanes);
                    var legRowHeight = Rem(LaneMinHeightRem(legLaneCount));
                    <div class="ttl-leg-label" style="min-height:@(legRowHeight)rem" @onclick="() => SelectLegAsync(leg.TripLegId)" role="button" tabindex="0">
                        <div class="fw-semibold">@leg.Title</div>
                        @if (!string.IsNullOrWhiteSpace(leg.Origin) || !string.IsNullOrWhiteSpace(leg.Destination))
                        {
                            <div class="small text-secondary">@leg.Origin @(string.IsNullOrWhiteSpace(leg.Origin) || string.IsNullOrWhiteSpace(leg.Destination) ? null : "→") @leg.Destination</div>
                        }
                        <div class="ttl-leg-meta">
                            <span class="ttl-leg-count @(leg.Items.Count == 0 ? "ttl-leg-count-empty" : null)">@EventCountLabel(leg.Items.Count)</span>
                            @if (CanEdit)
                            {
                                <button type="button"
                                        class="ttl-leg-add"
                                        title="Add an event to @leg.Title"
                                        aria-label="Add an event to @leg.Title"
                                        @onclick="() => AddEventToLegAsync(leg)"
                                        @onclick:stopPropagation="true">
                                    <span aria-hidden="true">+</span> Add event
                                </button>
                            }
                        </div>
                        <div class="ttl-leg-estimate small text-secondary">
                            <span>Estimated total: @leg.EstimatedCostTotal.ToString("C")</span>
                        </div>
                    </div>
                    <div class="ttl-lane @(CanEdit ? "ttl-lane-clickable" : null)" style="width:@(TrackWidthPx)px; min-height:@(legRowHeight)rem" @onclick="args => OnLaneClickAsync(leg, args)">
                        @laneGrid
                        @{
                            var band = ComputeSpan(leg.StartLocal, leg.EndLocal);
                        }
                        <div class="ttl-leg-band" style="left:@(band.Left)px; width:@(band.Width)px"></div>
                        @foreach (var (item, lane) in legLanes)
                        {
                            var localStart = item.StartLocal;
                            DateTime? localEnd = item.EndLocal;
                            var span = ComputeSpan(localStart, localEnd);
                            var outside = item.StartsOutsideLeg || item.EndsOutsideLeg;
                            <button type="button"
                                    class="ttl-item @(outside ? "is-outside" : null)"
                                    style="left:@(span.Left)px; width:@(span.Width)px; top:@(Rem(ItemTopRem(lane)))rem; --tp-item:@SwatchColor(item.DisplayColor)"
                                    title="@ItemTooltip(item, localStart, localEnd, outside)"
                                    @onclick="() => SelectItemAsync(item.TrackedItemId)"
                                    @onclick:stopPropagation="true">
                                <span class="ttl-item-title text-truncate">@item.Title</span>
                            </button>
                        }
                    </div>
                }

                @if (_timeline.UnassignedItems.Count > 0)
                {
                    var unassignedLanes = AssignLanes(_timeline.UnassignedItems);
                    var unassignedRowHeight = Rem(LaneMinHeightRem(LaneCount(unassignedLanes)));
                    <div class="ttl-leg-label ttl-leg-label-muted" style="min-height:@(unassignedRowHeight)rem">
                        <div class="fw-semibold text-truncate">Unassigned</div>
                        <div class="small text-secondary fst-italic">Needs a trip leg</div>
                    </div>
                    <div class="ttl-lane" style="width:@(TrackWidthPx)px; min-height:@(unassignedRowHeight)rem">
                        @laneGrid
                        @foreach (var (item, lane) in unassignedLanes)
                        {
                            var localStart = item.StartLocal;
                            DateTime? localEnd = item.EndLocal;
                            var span = ComputeSpan(localStart, localEnd);
                            <button type="button"
                                    class="ttl-item is-outside"
                                    style="left:@(span.Left)px; width:@(span.Width)px; top:@(Rem(ItemTopRem(lane)))rem; --tp-item:@SwatchColor(item.DisplayColor)"
                                    title="Unassigned event — select to relate it to a trip leg"
                                    @onclick="() => SelectItemAsync(item.TrackedItemId)">
                                <span class="ttl-item-title text-truncate">@item.Title</span>
                            </button>
                        }
                    </div>
                }

                @if (CanEdit)
                {
                    <div class="ttl-leg-footer">
                        <button type="button"
                                class="ttl-leg-add ttl-leg-add-footer"
                                title="Add a trip leg"
                                aria-label="Add a trip leg"
                                @onclick="AddLegFromFooterAsync">
                            <span aria-hidden="true">+</span> Add leg
                        </button>
                    </div>
                    <div class="ttl-footer-spacer" style="width:@(TrackWidthPx)px"></div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid TripId { get; set; }
    [Parameter] public bool CanEdit { get; set; } = true;
    [Parameter] public EventCallback<Guid> OnLegSelected { get; set; }
    [Parameter] public EventCallback<Guid> OnItemSelected { get; set; }
    [Parameter] public EventCallback<TimelineSlotSelection> OnLegSlotSelected { get; set; }
    [Parameter] public EventCallback OnAddLegRequested { get; set; }
    [Parameter] public EventCallback OnLoaded { get; set; }

    public sealed record TimelineSlotSelection(Guid TripLegId, DateTime StartLocal);


    private const int SlotWidthPx = 26;
    private const int LabelWidthPx = 220;
    private const int SlotMinutes = 30;
    private const int SlotsPerDay = 24 * 60 / SlotMinutes;

    // Vertical stacking of overlapping events within a leg row (values in rem).
    private const double DefaultRowHeightRem = 3.75;
    private const double ItemLaneHeightRem = 1.6;
    private const double LaneGapRem = 0.3;
    private const double LanePadRem = 0.35;
    // Clickable buffer reserved below the last lane so a time slot can always be clicked
    // to add another event, even when the lanes are full.
    private const double LaneBottomBufferRem = 1.4;

    private TripTimelineResponse? _timeline;
    private DateOnly _start;
    private DateOnly _end;
    private int _days;
    private ElementReference _scrollEl;
    private bool _disposed;

    private bool HasGrid => _timeline is not null && (_timeline.Legs.Count > 0 || _timeline.UnassignedItems.Count > 0);

    private int TrackWidthPx => _days * SlotsPerDay * SlotWidthPx;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed || !HasGrid)
        {
            return;
        }
        try
        {
            await JS.InvokeVoidAsync("tripTimeline.init", _scrollEl);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    public async Task RefreshAsync()
    {
        _timeline = await TripApi.GetTimelineAsync(TripId);
        if (_timeline is not null)
        {
            _start = _timeline.StartDate;
            _end = _timeline.EndDate;
            _days = Math.Max(1, _end.DayNumber - _start.DayNumber + 1);
        }
        StateHasChanged();
        // Notify the host so header controls that depend on this component's data
        // (e.g. the Jump-to-date list) re-render once the timeline has loaded.
        await OnLoaded.InvokeAsync();
    }

    // ── Date navigation ────────────────────────────────────────────────
    private DateOnly? _currentDate;

    /// <summary>Every date in the trip range, start to end inclusive. Empty until loaded.</summary>
    public IReadOnlyList<DateOnly> TripDates
    {
        get
        {
            if (_timeline is null)
            {
                return Array.Empty<DateOnly>();
            }
            var dates = new List<DateOnly>(_days);
            for (var d = 0; d < _days; d++)
            {
                dates.Add(_start.AddDays(d));
            }
            return dates;
        }
    }

    /// <summary>The date the timeline is currently positioned on, or null before any navigation.</summary>
    public DateOnly? CurrentDate => _currentDate;

    /// <summary>True when today's local date falls within the trip range.</summary>
    public bool TodayInRange
    {
        get
        {
            if (_timeline is null)
            {
                return false;
            }
            var today = DateOnly.FromDateTime(DateTime.Now);
            return today >= _start && today <= _end;
        }
    }

    // The effective focus defaults to the trip start (initial scroll position) until the user navigates.
    private DateOnly EffectiveCurrent => _currentDate ?? _start;

    /// <summary>True when the timeline is positioned on (or before) the first trip day.</summary>
    public bool AtTripStart => _timeline is null || EffectiveCurrent <= _start;

    /// <summary>True when the timeline is positioned on (or after) the last trip day.</summary>
    public bool AtTripEnd => _timeline is null || EffectiveCurrent >= _end;

    /// <summary>Scrolls the timeline so the given day's left edge aligns to the start of the scroll track.</summary>
    public async Task ScrollToDateAsync(DateOnly date)
    {
        if (_timeline is null || !HasGrid || _disposed)
        {
            return;
        }
        var clamped = date < _start ? _start : date > _end ? _end : date;
        _currentDate = clamped;
        var dayIndex = clamped.DayNumber - _start.DayNumber;
        var offsetX = dayIndex * SlotsPerDay * SlotWidthPx;
        StateHasChanged();
        try
        {
            await JS.InvokeVoidAsync("tripTimeline.scrollToDate", _scrollEl, offsetX);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    public Task GoToNextDayAsync()
    {
        if (_timeline is null)
        {
            return Task.CompletedTask;
        }
        var target = EffectiveCurrent.AddDays(1);
        return target <= _end ? ScrollToDateAsync(target) : Task.CompletedTask;
    }

    public Task GoToPreviousDayAsync()
    {
        if (_timeline is null)
        {
            return Task.CompletedTask;
        }
        var target = EffectiveCurrent.AddDays(-1);
        return target >= _start ? ScrollToDateAsync(target) : Task.CompletedTask;
    }

    public Task GoToTripStartAsync() => ScrollToDateAsync(_start);

    public Task GoToTripEndAsync() => ScrollToDateAsync(_end);

    public Task GoToTodayAsync()
        => TodayInRange ? ScrollToDateAsync(DateOnly.FromDateTime(DateTime.Now)) : Task.CompletedTask;

    private async Task AddLegFromFooterAsync() => await OnAddLegRequested.InvokeAsync();


    private (int Left, int Width) ComputeSpan(DateTime localStart, DateTime? localEnd)
    {
        var origin = _start.ToDateTime(TimeOnly.MinValue);
        var totalSlots = _days * SlotsPerDay;
        var startMinutes = (localStart - origin).TotalMinutes;
        var startSlot = Math.Clamp((int)Math.Floor(startMinutes / SlotMinutes), 0, totalSlots - 1);

        double durationMinutes = 60;
        if (localEnd is { } end)
        {
            durationMinutes = Math.Max(SlotMinutes, (end - localStart).TotalMinutes);
        }
        var spanSlots = Math.Clamp((int)Math.Ceiling(durationMinutes / SlotMinutes), 1, totalSlots - startSlot);
        return (startSlot * SlotWidthPx, Math.Max(SlotWidthPx, spanSlots * SlotWidthPx));
    }

    // Greedy interval-graph lane assignment: overlapping events are pushed onto separate
    // vertical lanes so they stack instead of covering each other. Items arrive ordered by
    // start time from the timeline projection.
    private static IReadOnlyList<(TimelineItem Item, int Lane)> AssignLanes(IReadOnlyList<TimelineItem> items)
    {
        var laneEnds = new List<DateTime>();
        var result = new List<(TimelineItem Item, int Lane)>(items.Count);
        foreach (var item in items)
        {
            var start = item.StartLocal;
            var end = item.EndLocal ?? start;
            if (end <= start)
            {
                end = start.AddMinutes(SlotMinutes);
            }

            var lane = -1;
            for (var i = 0; i < laneEnds.Count; i++)
            {
                if (laneEnds[i] <= start)
                {
                    lane = i;
                    break;
                }
            }

            if (lane == -1)
            {
                lane = laneEnds.Count;
                laneEnds.Add(end);
            }
            else
            {
                laneEnds[lane] = end;
            }

            result.Add((item, lane));
        }

        return result;
    }

    private static int LaneCount(IReadOnlyList<(TimelineItem Item, int Lane)> laneItems)
        => laneItems.Count == 0 ? 0 : laneItems.Max(x => x.Lane) + 1;

    private static double ItemTopRem(int lane) => LanePadRem + lane * (ItemLaneHeightRem + LaneGapRem);

    private static double LaneMinHeightRem(int laneCount)
    {
        var lanes = Math.Max(laneCount, 1);
        var contentHeight = LanePadRem + (lanes * ItemLaneHeightRem) + ((lanes - 1) * LaneGapRem) + LaneBottomBufferRem;
        return Math.Max(DefaultRowHeightRem, contentHeight);
    }

    private static string Rem(double value) => value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private async Task SelectLegAsync(Guid tripLegId) => await OnLegSelected.InvokeAsync(tripLegId);

    private async Task SelectItemAsync(Guid trackedItemId) => await OnItemSelected.InvokeAsync(trackedItemId);

    private async Task AddEventToLegAsync(TimelineLeg leg)
        => await OnLegSlotSelected.InvokeAsync(new TimelineSlotSelection(leg.TripLegId, leg.StartLocal));

    private async Task OnLaneClickAsync(TimelineLeg leg, MouseEventArgs args)
    {
        if (!CanEdit) return;
        var totalSlots = _days * SlotsPerDay;
        var slotIndex = Math.Clamp((int)Math.Floor(args.OffsetX / SlotWidthPx), 0, totalSlots - 1);
        var startLocal = _start.ToDateTime(TimeOnly.MinValue).AddMinutes(slotIndex * SlotMinutes);
        await OnLegSlotSelected.InvokeAsync(new TimelineSlotSelection(leg.TripLegId, startLocal));
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        try
        {
            await JS.InvokeVoidAsync("tripTimeline.dispose", _scrollEl);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
        catch (InvalidOperationException) { }
    }

    private static string FormatHour(int hour) => hour switch
    {
        0 => "12a",
        12 => "12p",
        < 12 => $"{hour}a",
        _ => $"{hour - 12}p"
    };

    private static string EventCountLabel(int count) => count switch
    {
        0 => "0 events",
        1 => "1 event",
        _ => $"{count} events"
    };

    private static string ItemTooltip(TimelineItem item, DateTime localStart, DateTime? localEnd, bool outside)
    {
        var when = localEnd is { } e ? $"{localStart:g} – {e:g}" : localStart.ToString("g");
        var suffix = outside ? " (outside leg range)" : string.Empty;
        return $"{item.Title} · {when}{suffix}";
    }

    private static string SwatchColor(string color) => color.ToLowerInvariant() switch
    {
        "slate" => "#64748b",
        "teal" => "#0d9488",
        "blue" => "#2563eb",
        "green" => "#2f7d57",
        "gold" => "#e7b85d",
        "orange" => "#c96f34",
        "red" => "#b42318",
        "purple" => "#7c3aed",
        "pink" => "#ec4899",
        "indigo" => "#4f46e5",
        "cyan" => "#06b6d4",
        "lime" => "#84cc16",
        "amber" => "#f59e0b",
        "brown" => "#92400e",
        "magenta" => "#c026d3",
        "navy" => "#1e3a8a",
        _ => "#64748b"
    };
}
