<a class="brand-mark text-decoration-none @Class" href="/" aria-label="Trip Planner home">
    <span class="brand-mark-icon" aria-hidden="true">
        <svg class="brand-globe" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
            <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <circle cx="24" cy="24" r="17"/>
                <ellipse cx="24" cy="24" rx="7" ry="17"/>
                <path d="M7 24h34"/>
                <path d="M11 15h26"/>
                <path d="M11 33h26"/>
            </g>
        </svg>
    </span>
    @if (!Compact)
    {
        <span>Trip Planner</span>
    }
</a>

@code {
    [Parameter] public bool Compact { get; set; }
    [Parameter] public string? Class { get; set; }
}
