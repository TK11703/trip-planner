@using System.ComponentModel.DataAnnotations
@inject ITripApiClient TripApi

<EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="@FormName">
    <DataAnnotationsValidator />
    <div class="mb-2">
        <label class="form-label" for="leg-title">Title</label>
        <InputText id="leg-title" class="form-control" @bind-Value="_model.Title" />
        <ValidationMessage For="@(() => _model.Title)" />
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label">Origin</label>
            <InputText class="form-control" @bind-Value="_model.Origin" />
        </div>
        <div class="col-6">
            <label class="form-label">Destination</label>
            <InputText class="form-control" @bind-Value="_model.Destination" />
        </div>
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label">Start</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.StartAt" />
        </div>
        <div class="col-6">
            <label class="form-label">End</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.EndAt" />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label">Notes</label>
        <InputTextArea class="form-control" rows="2" @bind-Value="_model.Notes" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger py-2 small">@_error</div>
    }
    <button type="submit" class="btn btn-primary" disabled="@_submitting">@(IsEdit ? "Save leg" : "Add leg")</button>
</EditForm>

@code {
    private sealed class LegModel
    {
        [Required(ErrorMessage = "Title is required.")] public string Title { get; set; } = string.Empty;
        public string? Origin { get; set; }
        public string? Destination { get; set; }
        public DateTime StartAt { get; set; } = DateTime.UtcNow;
        public DateTime EndAt { get; set; } = DateTime.UtcNow.AddHours(1);
        public string? Notes { get; set; }
    }

    [Parameter] public Guid TripId { get; set; }
    [Parameter] public TripLegDto? Leg { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private LegModel _model = new();
    private string? _error;
    private bool _submitting;
    private Guid? _loadedLegId;

    private bool IsEdit => Leg is not null;
    private string FormName => IsEdit ? $"trip-leg-edit-{Leg!.TripLegId}" : "trip-leg-create";

    protected override void OnParametersSet()
    {
        if (Leg is null)
        {
            if (_loadedLegId is not null)
            {
                _model = new LegModel();
                _loadedLegId = null;
            }
            return;
        }

        if (_loadedLegId == Leg.TripLegId)
        {
            return;
        }

        _model = new LegModel
        {
            Title = Leg.Title,
            Origin = Leg.Origin,
            Destination = Leg.Destination,
            StartAt = Leg.StartAt.LocalDateTime,
            EndAt = (Leg.EndAt ?? Leg.StartAt).LocalDateTime,
            Notes = Leg.Notes
        };
        _loadedLegId = Leg.TripLegId;
    }

    private async Task SubmitAsync()
    {
        _error = null; _submitting = true;
        try
        {
            var request = new CreateTripLegRequest(
                _model.Title.Trim(),
                _model.Origin,
                _model.Destination,
                new DateTimeOffset(_model.StartAt.ToUniversalTime(), TimeSpan.Zero),
                new DateTimeOffset(_model.EndAt.ToUniversalTime(), TimeSpan.Zero),
                _model.Notes);
            if (Leg is null)
            {
                await TripApi.CreateLegAsync(TripId, request);
                _model = new LegModel();
            }
            else
            {
                await TripApi.UpdateLegAsync(TripId, Leg.TripLegId, new UpdateTripLegRequest(
                    request.Title,
                    request.Origin,
                    request.Destination,
                    request.StartAt,
                    request.EndAt,
                    request.Notes));
            }
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
