@using System.ComponentModel.DataAnnotations
@inject ITripApiClient TripApi
@inject TripPlanner.Web.Features.Timezones.ITimezoneOptionsProvider TimezoneOptions

<EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="@FormName">
    <DataAnnotationsValidator />
    <div class="mb-2">
        <label class="form-label" for="leg-title">Title</label>
        <InputText id="leg-title" class="form-control" @bind-Value="_model.Title" />
        <ValidationMessage For="@(() => _model.Title)" />
    </div>
    <div class="alert alert-info py-2 small mb-3" role="note">
        A trip leg is a single travel segment from one place to another. Fill in where you're leaving and arriving, along with the start/end dates, times, and time zones.
        <div class="mt-1 fst-italic">Example: Leaving Washington DC on 8/1/2026 at 8:35 AM EST and arriving in Honolulu on 8/1/2026 at 2:55 PM HST.</div>
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label">Origin</label>
            <InputText class="form-control" @bind-Value="_model.Origin" />
        </div>
        <div class="col-6">
            <label class="form-label">Destination</label>
            <InputText class="form-control" @bind-Value="_model.Destination" />
        </div>
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label">Start</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.StartAt" />
        </div>
        <div class="col-6">
            <label class="form-label">End</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.EndAt" />
        </div>
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label" for="leg-start-timezone">Start timezone</label>
            <InputSelect id="leg-start-timezone" class="form-select" @bind-Value="_model.StartTimeZoneId">
                <option value="">Select a timezone</option>
                @foreach (var option in TimezoneOptions.GetOptions())
                {
                    <option value="@option.Id">@option.DisplayName (@option.Id)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => _model.StartTimeZoneId)" />
        </div>
        <div class="col-6">
            <label class="form-label" for="leg-end-timezone">End timezone</label>
            <InputSelect id="leg-end-timezone" class="form-select" @bind-Value="_model.EndTimeZoneId">
                <option value="">Select a timezone</option>
                @foreach (var option in TimezoneOptions.GetOptions())
                {
                    <option value="@option.Id">@option.DisplayName (@option.Id)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => _model.EndTimeZoneId)" />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label">Notes</label>
        <InputTextArea class="form-control" rows="2" @bind-Value="_model.Notes" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger py-2 small">@_error</div>
    }
    <button type="submit" class="btn btn-primary" disabled="@_submitting">@(IsEdit ? "Save leg" : "Add leg")</button>
</EditForm>

@code {
    private sealed class LegModel
    {
        [Required(ErrorMessage = "Title is required.")] public string Title { get; set; } = string.Empty;
        public string? Origin { get; set; }
        public string? Destination { get; set; }
        public DateTime StartAt { get; set; } = DateTime.Now;
        public DateTime EndAt { get; set; } = DateTime.Now.AddHours(1);
        [Required(ErrorMessage = "Start timezone is required.")] public string StartTimeZoneId { get; set; } = "UTC";
        [Required(ErrorMessage = "End timezone is required.")] public string EndTimeZoneId { get; set; } = "UTC";
        public string? Notes { get; set; }
    }

    [Parameter] public Guid TripId { get; set; }
    [Parameter] public TripLegDto? Leg { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private LegModel _model = new();
    private string? _error;
    private bool _submitting;
    private Guid? _loadedLegId;
    private Guid? _defaultsLoadedForTripId;

    private bool IsEdit => Leg is not null;
    private string FormName => IsEdit ? $"trip-leg-edit-{Leg!.TripLegId}" : "trip-leg-create";

    protected override void OnParametersSet()
    {
        if (Leg is null)
        {
            if (_loadedLegId is not null)
            {
                _model = new LegModel();
                _loadedLegId = null;
                _defaultsLoadedForTripId = null;
            }
            return;
        }

        if (_loadedLegId == Leg.TripLegId)
        {
            return;
        }

        _model = new LegModel
        {
            Title = Leg.Title,
            Origin = Leg.Origin,
            Destination = Leg.Destination,
            StartAt = Leg.StartLocal,
            EndAt = Leg.EndLocal,
            StartTimeZoneId = Leg.StartTimeZoneId,
            EndTimeZoneId = Leg.EndTimeZoneId,
            Notes = Leg.Notes
        };
        _loadedLegId = Leg.TripLegId;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Leg is not null || _defaultsLoadedForTripId == TripId)
        {
            return;
        }

        var defaults = await TripApi.GetLegDefaultsAsync(TripId);
        if (defaults is not null)
        {
            _model.StartTimeZoneId = defaults.StartTimeZoneId;
            _model.EndTimeZoneId = defaults.EndTimeZoneId;
        }

        _defaultsLoadedForTripId = TripId;
    }

    private async Task SubmitAsync()
    {
        _error = null; _submitting = true;
        try
        {
            var request = new CreateTripLegRequest(
                _model.Title.Trim(),
                _model.Origin,
                _model.Destination,
                _model.StartAt,
                _model.StartTimeZoneId,
                _model.EndAt,
                _model.EndTimeZoneId,
                _model.Notes);
            if (Leg is null)
            {
                await TripApi.CreateLegAsync(TripId, request);
                _model = new LegModel
                {
                    StartTimeZoneId = request.EndTimeZoneId,
                    EndTimeZoneId = request.EndTimeZoneId
                };
                _defaultsLoadedForTripId = null;
            }
            else
            {
                await TripApi.UpdateLegAsync(TripId, Leg.TripLegId, new UpdateTripLegRequest(
                    request.Title,
                    request.Origin,
                    request.Destination,
                    request.StartLocal,
                    request.StartTimeZoneId,
                    request.EndLocal,
                    request.EndTimeZoneId,
                    request.Notes));
            }
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
