@using System.ComponentModel.DataAnnotations
@inject ITripApiClient TripApi

<EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="tracked-item-form">
    <DataAnnotationsValidator />
    <div class="row g-2 mb-2">
        <div class="col-5">
            <label class="form-label">Type</label>
            <InputSelect class="form-select" @bind-Value="_model.ItemType">
                <option value="activity">Activity</option>
                <option value="reservation">Reservation</option>
                <option value="event">Event</option>
                <option value="reminder">Reminder</option>
            </InputSelect>
        </div>
        <div class="col-7">
            <label class="form-label">Title</label>
            <InputText class="form-control" @bind-Value="_model.Title" />
            <ValidationMessage For="@(() => _model.Title)" />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label">Location</label>
        <InputText class="form-control" @bind-Value="_model.Location" />
    </div>
    <div class="row g-2 mb-2">
        <div class="col-6">
            <label class="form-label">Start</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.StartsAt" />
        </div>
        <div class="col-6">
            <label class="form-label">End</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_model.EndsAt" />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label">Confirmation code</label>
        <InputText class="form-control" @bind-Value="_model.ConfirmationCode" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger py-2 small">@_error</div>
    }
    <button type="submit" class="btn btn-primary btn-sm" disabled="@_submitting">Add item</button>
</EditForm>

@code {
    private sealed class ItemModel
    {
        public string ItemType { get; set; } = "activity";
        [Required(ErrorMessage = "Title is required.")] public string Title { get; set; } = string.Empty;
        public string? Location { get; set; }
        public DateTime StartsAt { get; set; } = DateTime.UtcNow;
        public DateTime EndsAt { get; set; } = DateTime.UtcNow.AddHours(1);
        public string? ConfirmationCode { get; set; }
        public string? Notes { get; set; }
    }

    [Parameter] public Guid TripId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ItemModel _model = new();
    private string? _error;
    private bool _submitting;

    private async Task SubmitAsync()
    {
        _error = null; _submitting = true;
        try
        {
            var request = new CreateTrackedItemRequest(
                _model.ItemType,
                _model.Title.Trim(),
                _model.Location,
                new DateTimeOffset(_model.StartsAt.ToUniversalTime(), TimeSpan.Zero),
                new DateTimeOffset(_model.EndsAt.ToUniversalTime(), TimeSpan.Zero),
                _model.ConfirmationCode,
                _model.Notes);
            await TripApi.CreateItemAsync(TripId, request);
            _model = new ItemModel();
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
