@inject ITripApiClient TripApi
@inject AuthenticationStateProvider AuthenticationStateProvider

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
        <div>
            <p class="brand-eyebrow mb-1">Base camp</p>
            <h2 class="h3 mb-0">Recent trips</h2>
            <p class="text-secondary mb-0">Jump back into the journeys you have been charting.</p>
        </div>
        <a class="btn btn-outline-primary" href="/trips/new">New trip</a>
    </div>

    @if (_isLoading)
    {
        <StateMessage Title="Loading your route notes…" Message="We are gathering your recent trips." Tone="info" Icon="⌛" />
    }
    else if (_error is not null)
    {
        <PublicContentFallback Title="We couldn't load your trips right now." Detail="@_error" />
    }
    else if (_trips.Count == 0)
    {
        <NoTripsEmptyState />
    }
    else
    {
        <div class="row g-3">
            @foreach (var trip in _trips)
            {
                <div class="col-md-6 col-lg-4">
                    <a class="card trip-card h-100 text-decoration-none text-reset shadow-sm" href="@($"/trips/{trip.TripId}")">
                        <div class="card-body d-flex flex-column gap-3">
                            <div>
                                <p class="brand-eyebrow mb-1">Journey</p>
                                <h3 class="h5 mb-1">@trip.Name</h3>
                                <p class="small text-secondary mb-0">@trip.StartDate.ToString("MMM d") – @trip.EndDate.ToString("MMM d, yyyy")</p>
                            </div>
                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <span class="badge rounded-pill text-bg-primary">@trip.ItemCount itinerary items</span>
                                <span aria-hidden="true">→</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</section>

@code {
    private bool _isLoading = true;
    private string? _error;
    private IReadOnlyList<TripSummary> _trips = Array.Empty<TripSummary>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            _isLoading = false;
            _error = "Sign in is required to access your trips.";
            return;
        }

        try
        {
            _trips = await TripApi.GetRecentAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
