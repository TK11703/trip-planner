@if (State == TripAccessStateKind.SignInRequired)
{
    <StateMessage Title="Sign in required" Message="Sign in with your Azure Entra account before loading personal trip data." Tone="info" Icon="🔐">
        <a class="btn btn-primary btn-sm" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
    </StateMessage>
}
else if (State == TripAccessStateKind.NotFoundOrDenied)
{
    <StateMessage Title="This trip isn't available" Message="If you expected to see a trip here, double check the link or return to your recent trips." Tone="warning" Icon="⚠">
        <a class="btn btn-outline-primary btn-sm" href="/">Recent trips</a>
    </StateMessage>
}
else if (State == TripAccessStateKind.ReauthRequired)
{
    <StateMessage Title="Your session has expired" Message="Sign in again to view your private trip details." Tone="info" Icon="↻">
        <a class="btn btn-primary btn-sm" href="MicrosoftIdentity/Account/SignIn">Sign in again</a>
    </StateMessage>
}
else if (State == TripAccessStateKind.Loading)
{
    <StateMessage Title="Loading trip…" Message="We are checking your private route notes." Tone="info" Icon="⌛" />
}

@code {
    public enum TripAccessStateKind { None, Loading, SignInRequired, NotFoundOrDenied, ReauthRequired }

    [Parameter] public TripAccessStateKind State { get; set; } = TripAccessStateKind.None;
}
