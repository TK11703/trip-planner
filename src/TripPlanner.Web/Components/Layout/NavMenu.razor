@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject INotificationApiClient NotificationApi

<nav class="navbar navbar-modern border-bottom sticky-top" aria-label="Primary navigation">
    <div class="container navbar-3col">
        <div class="navbar-3col-start">
            <BrandMark />
        </div>
        <ul class="navbar-nav navbar-3col-center flex-row">
            <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
            <AuthorizeView>
                <Authorized>
                    <li class="nav-item"><a class="nav-link" href="/trips">Trips</a></li>
                </Authorized>
            </AuthorizeView>
            <li class="nav-item"><a class="nav-link" href="/faq">FAQ</a></li>
            <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
        </ul>
        <div class="navbar-3col-end">
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle account-menu-toggle d-flex align-items-center gap-2 position-relative"
                           href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="account-avatar" aria-hidden="true">@AvatarInitial(context.User)</span>
                            <span class="account-name">@DisplayLabel(context.User)</span>
                            @if (_unreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                    <span class="visually-hidden">Unread notifications</span>
                                </span>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/profile">Profile</a></li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center justify-content-between gap-3" href="/notifications">
                                    <span>Notifications</span>
                                    @if (_unreadCount > 0)
                                    {
                                        <span class="notification-badge" aria-label="@($"{_unreadCount} unread notifications")">@DisplayCount</span>
                                    }
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" href="MicrosoftIdentity/Account/SignOut">Sign out</a></li>
                        </ul>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-primary" href="MicrosoftIdentity/Account/SignIn">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private int _unreadCount;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string DisplayCount => _unreadCount > 99 ? "99+" : _unreadCount.ToString();

    protected override async Task OnInitializedAsync()
    {
        // Only signed-in users have notifications. Skipping the call for anonymous visitors avoids
        // triggering an interactive sign-in/consent challenge (MSAL) during the first, unauthenticated
        // page load, which would otherwise surface as a MicrosoftIdentityWebChallengeUserException.
        if (AuthenticationStateTask is null)
        {
            return;
        }

        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            return;
        }

        try
        {
            _unreadCount = await NotificationApi.GetUnreadCountAsync();
        }
        catch
        {
            // Never let a notification-count failure (including a token/consent challenge) break the
            // navigation bar; simply show no badge.
            _unreadCount = 0;
        }
    }

    private static string DisplayLabel(ClaimsPrincipal user)
        => FirstNonEmpty(
            user.FindFirst("name")?.Value,
            user.FindFirst("preferred_username")?.Value,
            user.FindFirst(ClaimTypes.Email)?.Value,
            user.Identity?.Name) ?? "Account";

    private static string AvatarInitial(ClaimsPrincipal user)
    {
        var label = DisplayLabel(user).TrimStart();
        return string.IsNullOrEmpty(label) ? "?" : char.ToUpperInvariant(label[0]).ToString();
    }

    private static string? FirstNonEmpty(params string?[] values)
        => values.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v))?.Trim();
}
