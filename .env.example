# Copy to .env or use as a template for `dotnet user-secrets`.
# Real values are NEVER committed.

# Azure Entra (Web app registration)
AzureEntra__Instance=https://login.microsoftonline.com/
AzureEntra__Domain=your-tenant.onmicrosoft.com
AzureEntra__TenantId=00000000-0000-0000-0000-000000000000
AzureEntra__ClientId=00000000-0000-0000-0000-000000000000
AzureEntra__CallbackPath=/signin-oidc
AzureEntra__SignedOutCallbackPath=/signout-callback-oidc

# Azure Entra (API app registration / audience)
AzureEntra__Audience=api://00000000-0000-0000-0000-000000000000

# Aspire Postgres parameters
Parameters__postgres-user=tripplanner
Parameters__postgres-password=change-me
